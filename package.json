{
  "name": "chronolog",
  "version": "1.1.1",
  "description": "Opens a daily journal dashboard for writing entries and managing structured frontmatter fields.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "journal",
    "daily-notes"
  ],
  "author": "Clinamenic",
  "license": "MIT",
  "devDependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@types/node": "^22.0.0",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.25.0",
    "obsidian": "latest",
    "typescript": "^5.8.0"
  }
}
